# Backend API (Spring) base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Better Auth (identity authority)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-strong-random-secret

# Postgres used by Better Auth (same instance as the backend, separate tables)
DATABASE_URL=postgresql://tum:tum@localhost:5432/tum

# Spring internal service token (for Better Auth email hooks)
INTERNAL_SERVICE_TOKEN=dev-internal-token
INTERNAL_API_URL=http://localhost:8080

# Social OAuth (TUM-E01-F02) — leave blank until configured
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Canonical public URL — used in OpenGraph, sitemap, robots.txt. Defaults to
# https://tum-app.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token (per-property, from
# search.google.com/search-console). Leave blank to omit the verification meta tag entirely; a
# stale value would silently break ownership checks. After setting in Vercel, redeploy and
# request re-verification in Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ---- Polar.sh payments ----------------------------------------------------------------------
# Polar handles the entire subscription / checkout / billing portal. The plugin is registered
# only when POLAR_ACCESS_TOKEN is set, so leaving these blank is safe (the Pro CTA on the
# landing page just falls back to /signup).
#
# Setup:
#   1. Create an organization on https://sandbox.polar.sh (or polar.sh for prod).
#   2. Settings → Developers → Create Organization Access Token (OAT). Copy below.
#   3. Products → New Product → "Tûm Pro", recurring monthly, $20. Copy the product ID below.
#   4. Settings → Webhooks → Add endpoint pointing at
#      https://<your-domain>/api/auth/polar/webhooks with format "Raw" and a random secret;
#      copy the secret below. Subscribe to subscription.* and order.* events at minimum.
#   5. Flip POLAR_SERVER to "production" once you've created the same setup on polar.sh.
POLAR_ACCESS_TOKEN=
POLAR_PRO_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
