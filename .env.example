# ─── Tûm Web — environment variables ─────────────────────────────────────────
#
# Copy to .env.local and override any value you need. Defaults below match
# Tûm's local Docker Compose stack so dev works out of the box after
# `docker compose up -d` in /infra.
#
# NEXT_PUBLIC_* vars are exposed to the browser. Everything else is server-only.
# In production, set these as real environment variables on Vercel (or your host);
# never commit .env.local.
# ──────────────────────────────────────────────────────────────────────────────


# ─── Backend (Spring) ────────────────────────────────────────────────────────
# Public — used by the browser to call the Spring REST API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Server-only — used by Better Auth lifecycle hooks (email send) + the Polar
# webhook bridge to call the backend's /internal/** endpoints. In Docker-to-
# Docker networking, use the container service name (http://app:8080).
INTERNAL_API_URL=http://localhost:8080


# ─── Better Auth (identity authority) ────────────────────────────────────────
# Server-only — the canonical Better Auth callback / cookie domain.
BETTER_AUTH_URL=http://localhost:3000
# Public — used by the React client to know which origin owns the session.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Server-only — signs the session cookie. Generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=replace-with-a-strong-random-secret

# Postgres used by Better Auth (same instance as the backend, separate schema).
DATABASE_URL=postgresql://tum:tum@localhost:5432/tum


# ─── Internal service token (shared with backend) ────────────────────────────
# Must match INTERNAL_SERVICE_TOKEN in tum/app/.env.local. The web app uses it
# when forwarding Polar webhooks to /internal/billing/subscription and when the
# backend calls back to /api/internal/organization/{id}/members.
INTERNAL_SERVICE_TOKEN=dev-internal-token


# ─── Social OAuth ────────────────────────────────────────────────────────────
# Leave blank to disable the corresponding provider (Better Auth logs a WARN
# at boot, which is expected when not configured).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# ─── SEO / public URL ────────────────────────────────────────────────────────
# Canonical public URL — drives OpenGraph, sitemap.xml, robots.txt. Defaults to
# https://tum-app.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token (per-property, from
# search.google.com/search-console). Leave blank to omit the verification meta
# tag entirely — a stale value would silently break ownership checks. After
# setting in Vercel, redeploy and re-verify in Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=


# ─── Polar.sh payments ───────────────────────────────────────────────────────
# Polar handles the entire subscription / checkout / billing portal. The plugin
# is registered only when POLAR_ACCESS_TOKEN is set, so leaving these blank is
# safe — the Pro CTA on the landing page just falls back to /signup.
#
# Setup:
#   1. Create an organisation on https://sandbox.polar.sh (or polar.sh for prod).
#   2. Settings → Developers → Organization Access Tokens → New token. Tick
#      "Select all" — the adapter needs customers:write, subscriptions:read,
#      customer_sessions:write, checkouts:write at minimum. Copy below.
#   3. Products → New Product → "Tûm Pro", recurring monthly $20 + annual $204.
#      Copy the Product ID into POLAR_PRO_PRODUCT_ID below.
#   4. Repeat for "Tûm Enterprise", $99/mo + $1008/yr → POLAR_ENTERPRISE_PRODUCT_ID.
#   5. Settings → Webhooks → Add endpoint
#      https://<your-domain>/api/auth/polar/webhooks, format "Raw", random
#      secret. Subscribe to subscription.* and order.* events. Copy secret below.
#   6. Flip POLAR_SERVER to "production" once you've done the same on polar.sh.
POLAR_ACCESS_TOKEN=
POLAR_PRO_PRODUCT_ID=
POLAR_ENTERPRISE_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox

# IMPORTANT: TUM_CLOUD_ENABLED is a BACKEND env var (lives in tum/app/.env.local
# as TUM_CLOUD_ENABLED=true). It controls whether the Spring EntitlementGate
# enforces subscriptions. The web app never reads it — don't set it here.
